# validate_recipes.cyr — Cyrius-native recipe validator for bazaar
#
# Walks recipes/ and checks every .cyml for required keys,
# filename-matches-package-name, and sha256 format.
#
# NOTE: The cyrius stdlib `toml` parser currently flattens sections
# (treats `[package]` as an unknown line and collects all keys in one
# namespace). Section-level checks are therefore coarse — we verify
# required keys exist *somewhere* in the recipe. A future pass can
# switch to nous' `cyml_parse` once it lands in stdlib.
#
# Build: cyrius build scripts/validate_recipes.cyr build/bazaar-validate
# Run:   ./build/bazaar-validate   (from repo root)

var g_errors = 0;
var g_warnings = 0;
var g_cmdline[4096];
var g_cmdline_len = 0;
# Universe of package names bazaar recipes may depend on. Backed by a hashmap
# for O(1) membership lookups — recipe dep lists reference ~900 names total,
# so the linear-scan alternative added ~2ms to validator runtime.
# zugot provides seed names via dist/zugot.cyr ([deps.zugot] in cyrius.cyml);
# bazaar adds its own names in a lightweight first pass.
var g_pkg_universe = 0;

# Read /proc/self/cmdline into our global buffer.
# Stdlib args_init stores a stack pointer in a global — dangles. We use
# a global buffer so the pointer stays valid for the life of the program.
fn read_cmdline() {
    var fd = syscall(2, "/proc/self/cmdline", 0, 0);
    if (fd < 0) { return 0; }
    g_cmdline_len = syscall(0, fd, &g_cmdline, 4096);
    syscall(3, fd);
    return g_cmdline_len;
}

# Return pointer to the nth null-terminated argv string, or 0 if absent.
fn arg_at(n) {
    if (g_cmdline_len <= 0) { return 0; }
    if (n == 0) { return &g_cmdline; }
    var count = 0;
    var i = 0;
    while (i < g_cmdline_len) {
        if (load8(&g_cmdline + i) == 0) {
            count = count + 1;
            if (count == n) {
                if (i + 1 >= g_cmdline_len) { return 0; }
                return &g_cmdline + i + 1;
            }
        }
        i = i + 1;
    }
    return 0;
}

fn print_cstr(s) {
    syscall(1, 1, s, strlen(s));
    return 0;
}

fn println_cstr(s) {
    print_cstr(s);
    syscall(1, 1, "\n", 1);
    return 0;
}

fn report_error(path, msg) {
    str_print(path);
    print_cstr(": error: ");
    print_cstr(msg);
    syscall(1, 1, "\n", 1);
    g_errors = g_errors + 1;
    return 0;
}

fn report_warn(path, msg) {
    str_print(path);
    print_cstr(": warning: ");
    print_cstr(msg);
    syscall(1, 1, "\n", 1);
    g_warnings = g_warnings + 1;
    return 0;
}

fn require_key(pairs, key, path) {
    if (toml_get(pairs, key) == 0) {
        str_print(path);
        print_cstr(": error: missing key '");
        print_cstr(key);
        println_cstr("'");
        g_errors = g_errors + 1;
    }
    return 0;
}

fn is_hex64(s) {
    if (str_len(s) != 64) { return 0; }
    var data = str_data(s);
    var i = 0;
    while (i < 64) {
        var c = load8(data + i);
        var ok = 0;
        if (c >= 48 && c <= 57) { ok = 1; }
        if (c >= 97 && c <= 102) { ok = 1; }
        if (c >= 65 && c <= 70) { ok = 1; }
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn recipe_stem(path) {
    var base = path_basename(path);
    var blen = str_len(base);
    # strip ".cyml" (5 chars)
    if (blen > 5) { return str_substr(base, 0, blen - 5); }
    return base;
}

# universe_contains(name_str) — O(1) hashmap lookup. Name must be a Str.
fn universe_contains(name) {
    return map_has(g_pkg_universe, str_cstr(name));
}

# First-pass helper: cheaply read a recipe and extract [package].name without
# running the full TOML parser. Matches the first line of the form
# `name = "..."` (ignoring surrounding whitespace). Much faster than re-parsing
# every recipe twice — saves ~3ms on the 90-recipe corpus.
fn collect_bazaar_name(path) {
    var buf = alloc(8192);
    var n = file_read_all(str_cstr(path), buf, 8192);
    if (n <= 0) { return 0; }
    var i = 0;
    while (i + 7 < n) {
        # Scan to start of line
        if (i == 0 || load8(buf + i - 1) == 10) {
            # Skip leading spaces/tabs
            var s = i;
            while (s < n) {
                var c = load8(buf + s);
                if (c != 32 && c != 9) { break; }
                s = s + 1;
            }
            # Look for literal "name" followed by = and quoted value
            if (s + 6 < n
                && load8(buf + s)     == 110   # n
                && load8(buf + s + 1) ==  97   # a
                && load8(buf + s + 2) == 109   # m
                && load8(buf + s + 3) == 101   # e
            ) {
                var p = s + 4;
                while (p < n) {
                    var c = load8(buf + p);
                    if (c != 32 && c != 9) { break; }
                    p = p + 1;
                }
                if (p < n && load8(buf + p) == 61) {  # =
                    p = p + 1;
                    while (p < n) {
                        var c = load8(buf + p);
                        if (c != 32 && c != 9) { break; }
                        p = p + 1;
                    }
                    if (p < n && load8(buf + p) == 34) {  # opening quote
                        var vstart = p + 1;
                        var vend = vstart;
                        while (vend < n && load8(buf + vend) != 34) {
                            vend = vend + 1;
                        }
                        if (vend > vstart && vend < n) {
                            # Allocate a private null-terminated copy — buf will be reused.
                            var len = vend - vstart;
                            var dst = alloc(len + 1);
                            memcpy(dst, buf + vstart, len);
                            store8(dst + len, 0);
                            map_set(g_pkg_universe, dst, 1);
                        }
                        return 0;
                    }
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# Check every runtime/build dep against the universe. Any dep that isn't
# provided by zugot and isn't the recipe's own name is an error.
fn check_deps(pairs, path, own_name) {
    var kinds = vec_new();
    vec_push(kinds, "runtime");
    vec_push(kinds, "build");
    var ki = 0;
    while (ki < vec_len(kinds)) {
        var kind = vec_get(kinds, ki);
        var raw = toml_get(pairs, kind);
        if (raw > 0) {
            # The flat-pair parser hands us the array as a raw Str like
            # `["glibc", "wayland", ...]`. We scan for quoted identifiers.
            var data = str_data(raw);
            var len = str_len(raw);
            var i = 0;
            while (i < len) {
                if (load8(data + i) == 34) {
                    # Walk to the closing quote.
                    var start = i + 1;
                    var end = start;
                    while (end < len && load8(data + end) != 34) {
                        end = end + 1;
                    }
                    if (end > start && end < len) {
                        var dep = str_new(data + start, end - start);
                        var skip = 0;
                        if (own_name > 0 && str_eq(dep, own_name) == 1) { skip = 1; }
                        if (skip == 0 && universe_contains(dep) == 0) {
                            str_print(path);
                            print_cstr(": error: dep '");
                            str_print(dep);
                            print_cstr("' (");
                            print_cstr(kind);
                            println_cstr(") not provided by zugot or bazaar");
                            g_errors = g_errors + 1;
                        }
                        i = end;
                    }
                }
                i = i + 1;
            }
        }
        ki = ki + 1;
    }
    return 0;
}

# Reject non-ASCII bytes in a package identifier. Blocks homoglyph attacks
# where a visually-identical Cyrillic/Greek character produces a name that
# visually matches an existing package but resolves differently at install time.
# Allowed: 0x20-0x7E (printable ASCII). In practice package names are much
# narrower (letters, digits, -, _, ., +), but we only fail on non-ASCII here;
# reviewers catch format violations within ASCII.
fn has_non_ascii(s) {
    var data = str_data(s);
    var len = str_len(s);
    var i = 0;
    while (i < len) {
        var c = load8(data + i);
        if (c < 32 || c > 126) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Detect shell metacharacters that would allow command injection if the value
# is interpolated into a `[build]` shell string without quoting. Returns 1 if
# the version looks dangerous.
fn version_has_shell_metachar(s) {
    var data = str_data(s);
    var len = str_len(s);
    if (len == 0) { return 0; }
    # Leading '-' can be misread as a flag by a build command.
    if (load8(data) == 45) { return 1; }
    var i = 0;
    while (i < len) {
        var c = load8(data + i);
        # ; & | $ ` ' " \ newline carriage-return
        if (c == 59 || c == 38 || c == 124) { return 1; }
        if (c == 36 || c == 96) { return 1; }
        if (c == 39 || c == 34 || c == 92) { return 1; }
        if (c == 10 || c == 13) { return 1; }
        i = i + 1;
    }
    return 0;
}

# url_is_https(s) returns 1 if s starts with the literal "https://".
fn url_is_https(s) {
    if (str_len(s) < 8) { return 0; }
    var data = str_data(s);
    if (load8(data)     != 104) { return 0; }  # h
    if (load8(data + 1) != 116) { return 0; }  # t
    if (load8(data + 2) != 116) { return 0; }  # t
    if (load8(data + 3) != 112) { return 0; }  # p
    if (load8(data + 4) != 115) { return 0; }  # s
    if (load8(data + 5) !=  58) { return 0; }  # :
    if (load8(data + 6) !=  47) { return 0; }  # /
    if (load8(data + 7) !=  47) { return 0; }  # /
    return 1;
}

fn validate_file(path) {
    var sections = toml_parse_file(str_cstr(path));
    if (vec_len(sections) == 0) {
        report_error(path, "parse error or empty file");
        return 0;
    }
    # Flat-pair mode: collect all pairs from all sections into one view.
    var pairs = toml_section_pairs(vec_get(sections, 0));

    require_key(pairs, "name", path);
    require_key(pairs, "version", path);
    require_key(pairs, "description", path);
    require_key(pairs, "license", path);
    require_key(pairs, "groups", path);
    require_key(pairs, "url", path);
    require_key(pairs, "sha256", path);
    require_key(pairs, "runtime", path);
    require_key(pairs, "make", path);
    require_key(pairs, "install", path);

    # Filename stem must match [package].name by default.
    # Recipes that ship parallel versions (e.g. python3.12 alongside python3.13)
    # or use filesystem-unsafe characters (libsigc++) can opt out by declaring
    # [package].pkgbase — filename stem then must match pkgbase instead.
    var name = toml_get(pairs, "name");
    var pkgbase = toml_get(pairs, "pkgbase");
    if (name > 0) {
        # Block homoglyph attacks — see docs/audit/2026-04-16.md F3.
        if (has_non_ascii(name) == 1) {
            report_error(path, "[package].name contains non-ASCII bytes (homoglyph risk)");
        }
        if (pkgbase > 0 && has_non_ascii(pkgbase) == 1) {
            report_error(path, "[package].pkgbase contains non-ASCII bytes (homoglyph risk)");
        }
        var stem = recipe_stem(path);
        var expected = name;
        var expected_label = "package name";
        if (pkgbase > 0) {
            expected = pkgbase;
            expected_label = "pkgbase";
        }
        if (str_eq(expected, stem) == 0) {
            str_print(path);
            print_cstr(": error: filename stem '");
            str_print(stem);
            print_cstr("' != ");
            print_cstr(expected_label);
            print_cstr(" '");
            str_print(expected);
            println_cstr("'");
            g_errors = g_errors + 1;
        }
    }

    var version = toml_get(pairs, "version");
    var url = toml_get(pairs, "url");
    # Shell-metachar check on version — see docs/audit/2026-04-16.md F5.
    if (version > 0 && version_has_shell_metachar(version) == 1) {
        report_warn(path, "version has shell metachars or leading '-' (command-injection risk in [build])");
    }
    # HTTPS-only URL enforcement — see docs/audit/2026-04-16.md F4.
    if (url > 0 && str_len(url) > 0 && url_is_https(url) == 0) {
        report_error(path, "[source].url must use https:// scheme");
    }
    if (version > 0 && url > 0 && str_len(version) > 0) {
        if (str_contains(url, version) == 0) {
            report_warn(path, "version string not found in source url");
        }
    }

    var sha = toml_get(pairs, "sha256");
    if (sha > 0) {
        var slen = str_len(sha);
        if (slen == 0) {
            report_warn(path, "sha256 is empty (must be populated before merge)");
        } elif (is_hex64(sha) == 0) {
            report_error(path, "sha256 is not a 64-char hex digest");
        }
    }

    check_deps(pairs, path, name);
    return 0;
}

fn main() {
    alloc_init();
    read_cmdline();

    var root_cstr = arg_at(1);
    var root = str_from("recipes");
    if (root_cstr != 0) { root = str_from(root_cstr); }

    # Populate the dep universe: zugot (via the deps-resolved module) plus
    # every bazaar package name collected in a first pass over the recipe tree.
    # Backed by a hashmap for O(1) membership checks during the main validate loop.
    g_pkg_universe = map_new();
    var zugot_vec = vec_new();
    zugot_names(zugot_vec);
    var zi = 0;
    while (zi < vec_len(zugot_vec)) {
        map_set(g_pkg_universe, str_cstr(vec_get(zugot_vec, zi)), 1);
        zi = zi + 1;
    }
    var zugot_count = map_size(g_pkg_universe);

    var files = find_files(root, str_from("cyml"));
    var total = vec_len(files);
    if (total == 0) {
        println_cstr("no .cyml recipes found under recipes/");
        return 2;
    }

    var i = 0;
    while (i < total) {
        collect_bazaar_name(vec_get(files, i));
        i = i + 1;
    }

    i = 0;
    while (i < total) {
        validate_file(vec_get(files, i));
        i = i + 1;
    }

    syscall(1, 1, "\n", 1);
    fmt_int(total);
    print_cstr(" recipes checked against ");
    fmt_int(zugot_count);
    print_cstr(" zugot + ");
    fmt_int(map_size(g_pkg_universe) - zugot_count);
    print_cstr(" bazaar pkgs — ");
    fmt_int(g_errors);
    print_cstr(" error(s), ");
    fmt_int(g_warnings);
    println_cstr(" warning(s)");

    if (g_errors > 0) { return 1; }
    return 0;
}

var exit_code = main();
syscall(60, exit_code);

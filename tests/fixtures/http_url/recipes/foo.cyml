# Insecure URL: http:// rather than https:// — MITM risk on source fetch.

[package]
name = "foo"
version = "1.0.0"
description = "non-https url fixture"
license = "MIT"
groups = ["tools"]

[source]
url = "http://example.org/foo-1.0.0.tar.gz"
sha256 = "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"

[depends]
runtime = ["glibc"]
build = ["gcc"]

[build]
make = "make"
install = "make install"

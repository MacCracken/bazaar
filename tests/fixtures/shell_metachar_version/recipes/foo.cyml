# Shell metacharacter in version — would inject if interpolated into [build].

[package]
name = "foo"
version = "1.0.0; rm -rf /"
description = "shell-metachar version fixture"
license = "MIT"
groups = ["tools"]

[source]
url = "https://example.org/foo-1.0.0.tar.gz"
sha256 = "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"

[depends]
runtime = ["glibc"]
build = ["gcc"]

[build]
make = "make"
install = "make install"

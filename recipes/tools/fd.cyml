# fd — simple, fast alternative to find

[package]
name = "fd"
version = "10.2.0"
description = "fd — simple, fast, user-friendly alternative to find"
license = "MIT"
groups = ["tools", "search"]

[source]
url = "https://github.com/sharkdp/fd/archive/refs/tags/v10.2.0.tar.gz"
sha256 = ""

[depends]
runtime = ["glibc"]
build = ["rust"]

[build]
configure = ""
make = "cargo build --release"
check = ""
install = """
mkdir -p $PKG/usr/bin
cp target/release/fd $PKG/usr/bin/
"""
